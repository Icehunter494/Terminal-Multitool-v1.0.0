while True:
        print("\n--- SYSTEM READY ---")
        choice = input("What would you like to open? (or type 'exit')\n>").lower()

        if choice == "exit":
            print("Shutting down...")
            break
        #checks apps dictionary
        elif choice == "help":
            print("\n --- Available Applications ---" "\n calculator \n assistant \n converter")
            

        elif choice in apps:
            apps[choice]()
        
        else:
            print(f"Sorry, '{choice}' is not a recognized app.")